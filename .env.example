# ── mcp-video-knowledge environment variables ──────────────────────────────
#
# ANTHROPIC_API_KEY (optional)
#   If set, the server uses claude-sonnet-4-5 for summarization, synthesis,
#   and video comparison. Without this key the server falls back to offline
#   TextRank-style extractive summarization.
#
ANTHROPIC_API_KEY=

# YOUTUBE_API_KEY (optional — only needed for keyword search)
#   Required for the `keyword` parameter in learn_topic / make_study_sheet.
#   NOT required if you pass explicit videoIds/URLs.
#   Get a key: https://console.developers.google.com/
#
YOUTUBE_API_KEY=

# BILIBILI_COOKIE (optional — Bilibili subtitle fetch)
#   Bilibili's subtitle API requires a logged-in session for most videos.
#   Copy the full Cookie header from your browser's DevTools → Network tab
#   while logged into bilibili.com and paste it here.
#   Without this cookie only a subset of public-CC videos will have subtitles.
#   Example: BILIBILI_COOKIE="SESSDATA=xxxx; bili_jct=xxxx; ..."
#
BILIBILI_COOKIE=
