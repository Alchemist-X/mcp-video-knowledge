# ── mcp-video-knowledge environment variables ──────────────────────────────
#
# ANTHROPIC_API_KEY (optional)
#   If set, the server uses Claude claude-sonnet-4-5 to summarize transcripts
#   and synthesize the cross-video script.
#   Without this key, the server falls back to rule-based extractive summarization.
#
ANTHROPIC_API_KEY=

# YOUTUBE_API_KEY (optional — only needed for keyword search)
#   Required for the `keyword` parameter in learn_topic.
#   NOT required if you pass explicit videoIds/URLs.
#   Get a key at: https://console.developers.google.com/
#
YOUTUBE_API_KEY=
